# Solana
SOLANA_RPC_URL=http://localhost:8899
ANCHOR_WALLET=~/.config/solana/id.json
PROGRAM_ID=

# PostgreSQL
DATABASE_URL=postgresql://payclear:payclear@localhost:5432/payclear

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3000
API_HOST=0.0.0.0

# Webhook
WEBHOOK_SIGNING_SECRET=

# Encryption — AES-256 master key for PII field encryption (envelope encryption)
# Must be exactly 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Back this key up securely. Loss of this key = loss of all encrypted PII.
PAYCLEAR_MASTER_KEY=

# Chainalysis KYT
CHAINALYSIS_API_KEY=
CHAINALYSIS_BASE_URL=https://api.chainalysis.com/api/kyt/v2
CHAINALYSIS_WEBHOOK_SECRET=
CHAINALYSIS_AUTO_REJECT_THRESHOLD=70
CHAINALYSIS_AUTO_REVOKE_THRESHOLD=85
