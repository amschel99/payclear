# Solana
SOLANA_RPC_URL=http://localhost:8899
ANCHOR_WALLET=~/.config/solana/id.json
PROGRAM_ID=

# PostgreSQL
DATABASE_URL=postgresql://payclear:payclear@localhost:5432/payclear

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3000
API_HOST=0.0.0.0

# Webhook
WEBHOOK_SIGNING_SECRET=

# Sumsub KYC
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_DEFAULT_LEVEL=basic-kyc-level

# Solana Attestation Service (SAS)
SAS_PROGRAM_ID=

# Encryption — AES-256 master key for PII field encryption (envelope encryption)
# Must be exactly 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Back this key up securely. Loss of this key = loss of all encrypted PII.
PAYCLEAR_MASTER_KEY=

# Chainalysis KYT
CHAINALYSIS_API_KEY=
CHAINALYSIS_BASE_URL=https://api.chainalysis.com/api/kyt/v2
CHAINALYSIS_WEBHOOK_SECRET=
CHAINALYSIS_AUTO_REJECT_THRESHOLD=70
CHAINALYSIS_AUTO_REVOKE_THRESHOLD=85

# Reclaim Protocol (ZK proof verification)
RECLAIM_APP_ID=
RECLAIM_APP_SECRET=
RECLAIM_TRUSTED_ATTESTORS=
RECLAIM_PROOF_TTL=86400
