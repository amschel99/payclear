{
  "name": "@payclear/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest",
    "lint": "eslint src/",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.1.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "drizzle-orm": "^0.33.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0",
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.6",
    "bullmq": "^5.12.0",
    "ioredis": "^5.4.0",
    "bcrypt": "^5.1.0",
    "nanoid": "^5.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "tsup": "^8.2.0",
    "vitest": "^2.0.0",
    "drizzle-kit": "^0.24.0",
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^22.0.0"
  }
}
